generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  AWAITING_DOCUMENTS
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

model User {
  id                   String               @id @default(uuid())
  name                 String
  email                String               @unique
  password             String
  phone                String?
  lgpdAccepted         Boolean              @default(false)
  lgpdAcceptedAt       DateTime?
  role                 Role                 @default(CLIENT)
  legalLogs            LegalAcceptanceLog[]
  termsAcceptedAt      DateTime?
  privacyAcceptedAt    DateTime?
  legalAcceptedVersion String?              @db.VarChar(30)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  orders        Order[]
  uploadedFiles UploadedFile[]
}

model Service {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  active       Boolean  @default(true)
  codePrefix   String?  @db.VarChar(10)
  requiredDocs Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Order {
  id          String      @id @default(uuid())
  orderCode   String?     @unique
  userId      String
  serviceId   String
  status      OrderStatus @default(PENDING_PAYMENT)
  totalAmount Float

  termsAccepted   Boolean   @default(false)
  termsAcceptedAt DateTime?

  privacyAccepted   Boolean   @default(false)
  privacyAcceptedAt DateTime?

  legalAcceptedVersion String? @db.VarChar(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  payments      Payment[]
  uploadedFiles UploadedFile[]
  histories     OrderStatusHistory[]
  documents     Document[]
  resultFiles   OrderResultFile[]

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@index([createdAt])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String
  orderId   String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String
  provider              String        @default("STRIPE")
  amount                Float
  status                PaymentStatus @default(PENDING)
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?
  checkoutUrl           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId])
  @@index([status])
}

model UploadedFile {
  id           String   @id @default(uuid())
  userId       String
  orderId      String
  type         String
  originalName String
  savedName    String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
}

model OrderCodeSequence {
  id         String   @id @default(uuid())
  prefix     String   @unique @db.VarChar(10)
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OrderResultFile {
  id           String   @id @default(uuid())
  orderId      String
  originalName String
  savedName    String?
  mimeType     String?
  size         Int?
  url          String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model StripeWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  orderId    String?
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
}

model LegalAcceptanceLog {
  id             String   @id @default(cuid())
  userId         String
  orderId        String?
  type           String // "REGISTER" | "CHECKOUT"
  termsVersion   String
  privacyVersion String
  acceptedAt     DateTime @default(now())
  ip             String?
  userAgent      String?

  user User @relation(fields: [userId], references: [id])
}
