generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  name                 String
  email                String               @unique
  password             String
  phone                String?
  role                 Role                 @default(CLIENT)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  legalAcceptedVersion String?              @db.VarChar(30)
  privacyAcceptedAt    DateTime?
  termsAcceptedAt      DateTime?
  lgpdAccepted         Boolean              @default(false)
  lgpdAcceptedAt       DateTime?
  legalLogs            LegalAcceptanceLog[]
  orders               Order[]
  uploadedFiles        UploadedFile[]
}

model Service {
  id           String   @id @default(uuid())
  name         String
  description  String?  // opcional agora
  price        Float

  type         String   @default("OUTRO")
  highlights   Json?    // bullets de conversão
  documents    Json?    // documentos necessários

  codePrefix   String?  @db.VarChar(10)
  active       Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
}

model Order {
  id                   String               @id @default(uuid())
  orderCode            String?              @unique
  userId               String
  serviceId            String
  status               OrderStatus          @default(PENDING_PAYMENT)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  legalAcceptedVersion String?              @db.VarChar(30)
  privacyAcceptedAt    DateTime?
  termsAcceptedAt      DateTime?
  totalAmount          Float
  privacyAccepted      Boolean              @default(false)
  termsAccepted        Boolean              @default(false)
  documents            Document[]
  service              Service              @relation(fields: [serviceId], references: [id])
  user                 User                 @relation(fields: [userId], references: [id])
  resultFiles          OrderResultFile[]
  histories            OrderStatusHistory[]
  payments             Payment[]
  uploadedFiles        UploadedFile[]

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@index([createdAt])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Document {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String
  orderId   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String
  status                PaymentStatus @default(PENDING)
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  amount                Float
  checkoutUrl           String?
  provider              String        @default("STRIPE")
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model UploadedFile {
  id           String   @id @default(uuid())
  userId       String
  orderId      String
  originalName String
  savedName    String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
  type         String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
}

model OrderCodeSequence {
  id         String   @id @default(uuid())
  prefix     String   @unique @db.VarChar(10)
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OrderResultFile {
  id           String   @id @default(uuid())
  orderId      String
  originalName String
  savedName    String?
  mimeType     String?
  size         Int?
  url          String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model StripeWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  orderId    String?
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
}

model LegalAcceptanceLog {
  id             String   @id @default(cuid())
  userId         String
  orderId        String?
  type           String
  termsVersion   String
  privacyVersion String
  acceptedAt     DateTime @default(now())
  ip             String?
  userAgent      String?
  user           User     @relation(fields: [userId], references: [id])
}

enum Role {
  CLIENT
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  AWAITING_DOCUMENTS
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}
